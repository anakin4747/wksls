# Associative array mapping URI -> document text.
declare -A DOC_TEXT

while recv; do
    method="$(printf '%s' "$BODY" | jq -r '.method // empty')"
    id="$(printf '%s' "$BODY" | jq -r '.id // empty')"

    case "$method" in
        initialize)
            send "{\"jsonrpc\":\"2.0\",\"id\":${id},\"result\":{\"capabilities\":{\"hoverProvider\":true,\"textDocumentSync\":{\"openClose\":true}}}}"
            ;;
        textDocument/didOpen)
            uri="$(printf '%s' "$BODY" | jq -r '.params.textDocument.uri')"
            text="$(printf '%s' "$BODY" | jq -r '.params.textDocument.text')"
            DOC_TEXT["$uri"]="$text"
            ;;
        textDocument/hover)
            uri="$(printf '%s' "$BODY" | jq -r '.params.textDocument.uri')"
            line="$(printf '%s' "$BODY" | jq -r '.params.position.line')"
            character="$(printf '%s' "$BODY" | jq -r '.params.position.character')"
            text="${DOC_TEXT["$uri"]:-}"
            word="$(word_at "$text" "$line" "$character")"
            case "$word" in
                bootloader)             send_hover "$id" "$BOOTLOADER_DOC" ;;
                part|partition)         send_hover "$id" "$PART_DOC" ;;
                --append)               send_hover "$id" "$APPEND_DOC" ;;
                --configfile)           send_hover "$id" "$CONFIGFILE_DOC" ;;
                --ptable)               send_hover "$id" "$PTABLE_DOC" ;;
                --timeout)              send_hover "$id" "$TIMEOUT_DOC" ;;
                --size)                 send_hover "$id" "$SIZE_DOC" ;;
                --fixed-size)           send_hover "$id" "$FIXED_SIZE_DOC" ;;
                --source)               send_hover "$id" "$SOURCE_DOC" ;;
                --ondisk|--ondrive)     send_hover "$id" "$ONDISK_DOC" ;;
                --fstype)               send_hover "$id" "$FSTYPE_DOC" ;;
                --fsoptions)            send_hover "$id" "$FSOPTIONS_DOC" ;;
                --label)                send_hover "$id" "$LABEL_DOC" ;;
                --active)               send_hover "$id" "$ACTIVE_DOC" ;;
                --align)                send_hover "$id" "$ALIGN_DOC" ;;
                --offset)               send_hover "$id" "$OFFSET_DOC" ;;
                --no-table)             send_hover "$id" "$NO_TABLE_DOC" ;;
                --exclude-path)         send_hover "$id" "$EXCLUDE_PATH_DOC" ;;
                --extra-filesystem-space) send_hover "$id" "$EXTRA_FILESYSTEM_SPACE_DOC" ;;
                --extra-partition-space)  send_hover "$id" "$EXTRA_PARTITION_SPACE_DOC" ;;
                --overhead-factor)      send_hover "$id" "$OVERHEAD_FACTOR_DOC" ;;
                --part-name)            send_hover "$id" "$PART_NAME_DOC" ;;
                --part-type)            send_hover "$id" "$PART_TYPE_DOC" ;;
                --use-uuid)             send_hover "$id" "$USE_UUID_DOC" ;;
                --uuid)                 send_hover "$id" "$UUID_DOC" ;;
                --fsuuid)               send_hover "$id" "$FSUUID_DOC" ;;
                --system-id)            send_hover "$id" "$SYSTEM_ID_DOC" ;;
                --mkfs-extraopts)       send_hover "$id" "$MKFS_EXTRAOPTS_DOC" ;;
                *)
                    send "{\"jsonrpc\":\"2.0\",\"id\":${id},\"result\":null}"
                    ;;
            esac
            ;;
        exit)
            exit 0
            ;;
    esac
done
