# Valid flags for each directive.
BOOTLOADER_FLAGS="--append --configfile --diskid --ptable --source --timeout"
PART_FLAGS="--active --align --change-directory --exclude-path --extra-filesystem-space --extra-partition-space --fixed-size --fsoptions --fspassno --fstype --fsuuid --hidden --include-path --label --mbr --mkfs-extraopts --no-fstab-update --no-table --offset --ondisk --ondrive --overhead-factor --part-name --part-type --rootfs --rootfs-dir --size --source --sourceparams --system-id --type --use-label --use-uuid --uuid"

# Valid values for enumerated flags.
FSTYPE_VALUES="btrfs efi erofs ext2 ext3 ext4 msdos squashfs swap vfat"
PTABLE_VALUES="gpt gpt-hybrid msdos"

# Return 0 if the given word is present in the given space-separated list.
_in_list() {
    local word="$1" list="$2" item
    for item in $list; do
        [[ "$item" == "$word" ]] && return 0
    done
    return 1
}

# Return the 0-based character offset of the first occurrence of the token
# in the given line text, or -1 if not found.
_token_offset() {
    local line_text="$1" token="$2"
    local before="${line_text%%"$token"*}"
    [[ "$before" == "$line_text" ]] && { printf '%d' -1; return; }
    printf '%d' "${#before}"
}

# Append one LSP diagnostic object to a JSON array.
# Usage: _append_diagnostic <diags-json> <line> <col-start> <col-end> <message>
# Prints the updated array.
_append_diagnostic() {
    local diags="$1" lineno="$2" col_start="$3" col_end="$4" msg="$5"
    jq -cn \
        --argjson diags "$diags" \
        --argjson sl "$lineno" --argjson sc "$col_start" \
        --argjson el "$lineno" --argjson ec "$col_end" \
        --arg msg "$msg" \
        '$diags + [{
            range: {
                start: {line: $sl, character: $sc},
                end:   {line: $el, character: $ec}
            },
            severity: 1,
            message: $msg
        }]'
}

# Validate a single enumerated flag value (--fstype or --ptable).
# Updates the global `diagnostics` variable.
# Usage: _validate_enum_value <lineno> <line_text> <flag_name> <value> <tok>
_validate_enum_value() {
    local lineno="$1" line_text="$2" flag_name="$3" value="$4" tok="$5"
    local col_start valid_list msg
    case "$flag_name" in
        --fstype) valid_list="$FSTYPE_VALUES" ; msg="Invalid --fstype value: $value" ;;
        --ptable) valid_list="$PTABLE_VALUES" ; msg="Invalid --ptable value: $value" ;;
        *) return ;;
    esac
    _in_list "$value" "$valid_list" && return
    col_start="$(_token_offset "$line_text" "$tok")"
    diagnostics="$(_append_diagnostic "$diagnostics" \
        "$lineno" "$col_start" $((col_start + ${#tok})) "$msg")"
}

# Validate one token from a directive line.
# Updates the globals `diagnostics`, `prev_flag`, and the `line_flags` associative
# array (passed by name) which maps flag names to their values (empty string for
# boolean flags).
# Usage: _validate_token <lineno> <line_text> <directive> <valid_flags> <tok> <line_flags_var>
_validate_token() {
    local lineno="$1" line_text="$2" directive="$3" valid_flags="$4" tok="$5"
    local -n _lf_ref="$6"
    local col_start flag_name flag_value

    if [[ -n "$prev_flag" && "$tok" != --* ]]; then
        _validate_enum_value "$lineno" "$line_text" "$prev_flag" "$tok" "$tok"
        _lf_ref["$prev_flag"]="$tok"
        prev_flag=""
        return
    fi
    prev_flag=""

    [[ "$tok" == --* ]] || return

    flag_name="${tok%%=*}"
    flag_value="${tok#*=}"
    [[ "$flag_name" == "$tok" ]] && flag_value=""

    col_start="$(_token_offset "$line_text" "$tok")"
    if ! _in_list "$flag_name" "$valid_flags"; then
        diagnostics="$(_append_diagnostic "$diagnostics" \
            "$lineno" "$col_start" $((col_start + ${#tok})) \
            "Unknown flag for $directive: $flag_name")"
        return
    fi

    _lf_ref["$flag_name"]="$flag_value"

    if [[ -n "$flag_value" ]]; then
        _validate_enum_value "$lineno" "$line_text" "$flag_name" "$flag_value" "$tok"
    else
        case "$flag_name" in
            --fstype|--ptable) prev_flag="$flag_name" ;;
        esac
    fi
}

# Check logical constraints between flags on a single directive line.
# Updates the global `diagnostics`.
# Usage: _validate_line_logic <lineno> <line_text> <directive> <line_flags_var>
_validate_line_logic() {
    local lineno="$1" line_text="$2" directive="$3"
    local -n _lf="$4"
    local col_start tok

    case "$directive" in
        part|partition)
            # --size and --fixed-size are mutually exclusive.
            if [[ -v _lf[--size] && -v _lf[--fixed-size] ]]; then
                tok="--fixed-size"
                col_start="$(_token_offset "$line_text" "$tok")"
                diagnostics="$(_append_diagnostic "$diagnostics" \
                    "$lineno" "$col_start" $((col_start + ${#tok})) \
                    "--size and --fixed-size are mutually exclusive")"
            fi

            # --fixed-size is incompatible with --overhead-factor.
            if [[ -v _lf[--fixed-size] && -v _lf[--overhead-factor] ]]; then
                tok="--overhead-factor"
                col_start="$(_token_offset "$line_text" "$tok")"
                diagnostics="$(_append_diagnostic "$diagnostics" \
                    "$lineno" "$col_start" $((col_start + ${#tok})) \
                    "--overhead-factor cannot be used with --fixed-size")"
            fi

            # --fixed-size is incompatible with --extra-filesystem-space.
            if [[ -v _lf[--fixed-size] && -v _lf[--extra-filesystem-space] ]]; then
                tok="--extra-filesystem-space"
                col_start="$(_token_offset "$line_text" "$tok")"
                diagnostics="$(_append_diagnostic "$diagnostics" \
                    "$lineno" "$col_start" $((col_start + ${#tok})) \
                    "--extra-filesystem-space cannot be used with --fixed-size")"
            fi

            local fstype="${_lf[--fstype]:-}"

            # squashfs and erofs do not support --label.
            if [[ "$fstype" == squashfs || "$fstype" == erofs ]] && [[ -v _lf[--label] ]]; then
                tok="--label"
                col_start="$(_token_offset "$line_text" "$tok")"
                diagnostics="$(_append_diagnostic "$diagnostics" \
                    "$lineno" "$col_start" $((col_start + ${#tok})) \
                    "--label is not supported with --fstype $fstype")"
            fi

            # squashfs does not support --fsuuid.
            if [[ "$fstype" == squashfs ]] && [[ -v _lf[--fsuuid] ]]; then
                tok="--fsuuid"
                col_start="$(_token_offset "$line_text" "$tok")"
                diagnostics="$(_append_diagnostic "$diagnostics" \
                    "$lineno" "$col_start" $((col_start + ${#tok})) \
                    "--fsuuid is not supported with --fstype squashfs")"
            fi

            # --use-label requires --label.
            if [[ -v _lf[--use-label] && ! -v _lf[--label] ]]; then
                tok="--use-label"
                col_start="$(_token_offset "$line_text" "$tok")"
                diagnostics="$(_append_diagnostic "$diagnostics" \
                    "$lineno" "$col_start" $((col_start + ${#tok})) \
                    "--use-label requires --label")"
            fi
            ;;
    esac
}

# Validate document text and print a JSON array of LSP diagnostic objects.
# Each diagnostic has: range, severity (1=Error), message.
validate_document() {
    local text="$1"
    local lineno=0
    local line_text directive stripped valid_flags
    local bootloader_seen=0
    diagnostics="[]"

    while IFS= read -r line_text; do
        line_text="${line_text%$'\r'}"

        stripped="${line_text%%#*}"
        stripped="${stripped#"${stripped%%[![:space:]]*}"}"  # ltrim
        stripped="${stripped%"${stripped##*[![:space:]]}"}"  # rtrim
        [[ -z "$stripped" ]] && { lineno=$((lineno + 1)); continue; }

        read -ra tokens <<< "$stripped"
        directive="${tokens[0]}"

        case "$directive" in
            bootloader|part|partition|include) ;;
            *)
                local col_start
                col_start="$(_token_offset "$line_text" "$directive")"
                diagnostics="$(_append_diagnostic "$diagnostics" "$lineno" \
                    "$col_start" $((col_start + ${#directive})) \
                    "Unknown directive: $directive")"
                lineno=$((lineno + 1))
                continue
                ;;
        esac

        case "$directive" in
            bootloader)
                bootloader_seen=$((bootloader_seen + 1))
                if [[ $bootloader_seen -gt 1 ]]; then
                    col_start="$(_token_offset "$line_text" "bootloader")"
                    diagnostics="$(_append_diagnostic "$diagnostics" "$lineno" \
                        "$col_start" $((col_start + ${#directive})) \
                        "Only one bootloader directive is allowed")"
                fi
                valid_flags="$BOOTLOADER_FLAGS"
                ;;
            part|partition) valid_flags="$PART_FLAGS" ;;
            include)        lineno=$((lineno + 1)); continue ;;
        esac

        # shellcheck disable=SC2034  # passed by name to _validate_token/_validate_line_logic
        local -A line_flags=()
        local i=1 prev_flag=""
        while [[ $i -lt ${#tokens[@]} ]]; do
            _validate_token "$lineno" "$line_text" "$directive" "$valid_flags" "${tokens[$i]}" line_flags
            i=$((i + 1))
        done

        _validate_line_logic "$lineno" "$line_text" "$directive" line_flags

        lineno=$((lineno + 1))
    done < <(printf '%s\n' "$text")

    printf '%s' "$diagnostics"
}

# Send a textDocument/publishDiagnostics notification.
publish_diagnostics() {
    local uri="$1" diagnostics="$2"
    local uri_json
    uri_json="$(jq -cn --arg u "$uri" '$u')"
    send "{\"jsonrpc\":\"2.0\",\"method\":\"textDocument/publishDiagnostics\",\"params\":{\"uri\":${uri_json},\"diagnostics\":${diagnostics}}}"
}

handle_completion() {
    local id="$1" text="$2" line="$3" character="$4"
    local flag directive
    flag="$(flag_at "$text" "$line" "$character")"
    [[ -z "$flag" ]] && flag="$(prev_flag_at "$text" "$line" "$character")"
    if [[ -n "$flag" ]]; then
        send_completion "$id" "$flag"
        return
    fi
    if line_start_at "$text" "$line" "$character"; then
        send_completion "$id" "keywords"
        return
    fi
    directive="$(directive_at "$text" "$line")"
    case "$directive" in
        bootloader) send_completion "$id" "bootloader_flags" ;;
        "")         send_completion "$id" "keywords" ;;
        *)          send_completion "$id" "part_flags" ;;
    esac
}

handle_definition() {
    local id="$1" text="$2" line="$3" character="$4" uri="$5"
    local plugin_name local_path oe_root target="" target_uri class_pos class_line class_char
    plugin_name="$(source_value_at "$text" "$line" "$character")" || true
    if [[ -n "$plugin_name" ]]; then
        local_path="${uri#file://}"
        oe_root="$(find_oe_root "$local_path")" || true
        [[ -n "$oe_root" ]] && target="$(source_plugin_path "$oe_root" "$plugin_name")" || true
    fi
    if [[ -n "$target" ]]; then
        target_uri="file://${target}"
        class_pos="$(plugin_class_position "$target")" || class_pos="0 0"
        class_line="${class_pos% *}"
        class_char="${class_pos#* }"
        send "{\"jsonrpc\":\"2.0\",\"id\":${id},\"result\":{\"uri\":$(jq -cn --arg u "$target_uri" '$u'),\"range\":{\"start\":{\"line\":${class_line},\"character\":${class_char}},\"end\":{\"line\":${class_line},\"character\":${class_char}}}}}"
    else
        send "{\"jsonrpc\":\"2.0\",\"id\":${id},\"result\":null}"
    fi
}

handle_hover() {
    local id="$1" text="$2" line="$3" character="$4"
    local plugin_name
    plugin_name="$(source_value_at "$text" "$line" "$character")" || true
    if [[ -n "$plugin_name" ]]; then
        case "$plugin_name" in
            rootfs)               send_hover "$id" "$SOURCE_PLUGIN_ROOTFS_DOC" ;;
            bootimg_efi)          send_hover "$id" "$SOURCE_PLUGIN_BOOTIMG_EFI_DOC" ;;
            bootimg_partition)    send_hover "$id" "$SOURCE_PLUGIN_BOOTIMG_PARTITION_DOC" ;;
            bootimg_pcbios)       send_hover "$id" "$SOURCE_PLUGIN_BOOTIMG_PCBIOS_DOC" ;;
            bootimg_biosplusefi)  send_hover "$id" "$SOURCE_PLUGIN_BOOTIMG_BIOSPLUSEFI_DOC" ;;
            empty)                send_hover "$id" "$SOURCE_PLUGIN_EMPTY_DOC" ;;
            extra_partition)      send_hover "$id" "$SOURCE_PLUGIN_EXTRA_PARTITION_DOC" ;;
            isoimage_isohybrid)   send_hover "$id" "$SOURCE_PLUGIN_ISOIMAGE_ISOHYBRID_DOC" ;;
            rawcopy)              send_hover "$id" "$SOURCE_PLUGIN_RAWCOPY_DOC" ;;
            *)                    send "{\"jsonrpc\":\"2.0\",\"id\":${id},\"result\":null}" ;;
        esac
        return
    fi
    case "$(word_at "$text" "$line" "$character")" in
        bootloader)               send_hover "$id" "$BOOTLOADER_DOC" ;;
        part|partition)           send_hover "$id" "$PART_DOC" ;;
        --append)                 send_hover "$id" "$APPEND_DOC" ;;
        --configfile)             send_hover "$id" "$CONFIGFILE_DOC" ;;
        --ptable)                 send_hover "$id" "$PTABLE_DOC" ;;
        --timeout)                send_hover "$id" "$TIMEOUT_DOC" ;;
        --size)                   send_hover "$id" "$SIZE_DOC" ;;
        --fixed-size)             send_hover "$id" "$FIXED_SIZE_DOC" ;;
        --source)                 send_hover "$id" "$SOURCE_DOC" ;;
        --sourceparams)           send_hover "$id" "$SOURCEPARAMS_DOC" ;;
        --ondisk|--ondrive)       send_hover "$id" "$ONDISK_DOC" ;;
        --fstype)                 send_hover "$id" "$FSTYPE_DOC" ;;
        --fsoptions)              send_hover "$id" "$FSOPTIONS_DOC" ;;
        --label)                  send_hover "$id" "$LABEL_DOC" ;;
        --active)                 send_hover "$id" "$ACTIVE_DOC" ;;
        --align)                  send_hover "$id" "$ALIGN_DOC" ;;
        --offset)                 send_hover "$id" "$OFFSET_DOC" ;;
        --no-table)               send_hover "$id" "$NO_TABLE_DOC" ;;
        --exclude-path)           send_hover "$id" "$EXCLUDE_PATH_DOC" ;;
        --extra-filesystem-space) send_hover "$id" "$EXTRA_FILESYSTEM_SPACE_DOC" ;;
        --extra-partition-space)  send_hover "$id" "$EXTRA_PARTITION_SPACE_DOC" ;;
        --overhead-factor)        send_hover "$id" "$OVERHEAD_FACTOR_DOC" ;;
        --part-name)              send_hover "$id" "$PART_NAME_DOC" ;;
        --part-type)              send_hover "$id" "$PART_TYPE_DOC" ;;
        --use-uuid)               send_hover "$id" "$USE_UUID_DOC" ;;
        --uuid)                   send_hover "$id" "$UUID_DOC" ;;
        --fsuuid)                 send_hover "$id" "$FSUUID_DOC" ;;
        --system-id)              send_hover "$id" "$SYSTEM_ID_DOC" ;;
        --mkfs-extraopts)         send_hover "$id" "$MKFS_EXTRAOPTS_DOC" ;;
        --rootfs-dir)             send_hover "$id" "$ROOTFS_DIR_DOC" ;;
        --rootfs)                 send_hover "$id" "$ROOTFS_DOC" ;;
        *)                        send "{\"jsonrpc\":\"2.0\",\"id\":${id},\"result\":null}" ;;
    esac
}

# Sets: method, id, uri, line, character (all from the current message).
parse_request() {
    local parsed
    parsed="$(printf '%s' "$BODY" | jq -r '
        (.method // ""),
        (.id // ""),
        (.params.textDocument.uri // ""),
        (.params.position.line // ""),
        (.params.position.character // "")
    ')"
    { IFS= read -r method
      IFS= read -r id
      IFS= read -r uri
      IFS= read -r line
      IFS= read -r character
    } <<< "$parsed" || :
}

# Associative array mapping URI -> document text.
declare -A DOC_TEXT

while recv; do
    parse_request

    case "$method" in
        initialize)
            send "{\"jsonrpc\":\"2.0\",\"id\":${id},\"result\":{\"capabilities\":{\"hoverProvider\":true,\"completionProvider\":{},\"definitionProvider\":true,\"textDocumentSync\":{\"openClose\":true,\"change\":1}}}}"
            ;;
        textDocument/didOpen)
            text="$(printf '%s' "$BODY" | jq -r '.params.textDocument.text')"
            DOC_TEXT["$uri"]="$text"
            publish_diagnostics "$uri" "$(validate_document "$text")"
            ;;
        textDocument/didChange)
            text="$(printf '%s' "$BODY" | jq -r '.params.contentChanges[-1].text')"
            DOC_TEXT["$uri"]="$text"
            publish_diagnostics "$uri" "$(validate_document "$text")"
            ;;
        textDocument/completion)
            handle_completion "$id" "${DOC_TEXT["$uri"]:-}" "$line" "$character"
            ;;
        textDocument/definition)
            handle_definition "$id" "${DOC_TEXT["$uri"]:-}" "$line" "$character" "$uri"
            ;;
        textDocument/hover)
            handle_hover "$id" "${DOC_TEXT["$uri"]:-}" "$line" "$character"
            ;;
        exit)
            exit 0
            ;;
    esac
done
