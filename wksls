#!/usr/bin/env bash
set -o errexit
set -o nounset
set -o pipefail

command -v jq > /dev/null || { printf 'wksls: jq is required but not found in PATH\n' >&2; exit 1; }

# Send a JSON-RPC message with a Content-Length header on stdout.
send() {
    local body="$1"
    local len
    len="$(printf '%s' "$body" | wc -c)"
    printf "Content-Length: %d\r\n\r\n%s" "$len" "$body"
}

# Read one JSON-RPC message from stdin into BODY.
recv() {
    local line content_length=0

    while IFS= read -r line; do
        line="${line%$'\r'}"
        [[ -z "$line" ]] && break
        if [[ "$line" =~ ^Content-Length:\ ([0-9]+)$ ]]; then
            content_length="${BASH_REMATCH[1]}"
        fi
    done

    [[ "$content_length" -eq 0 ]] && return 1

    IFS= read -r -N "$content_length" BODY
}

# Extract the full whitespace-delimited token containing the given character
# position, and the partial word up to (and including) that character.
# Sets TOKEN and WORD in the caller's scope.
_token_at() {
    local text="$1" line="$2" character="$3"
    local line_text
    line_text="$(printf '%s' "$text" | sed -n "$((line + 1))p")"
    local before="${line_text:0:$((character + 1))}"
    WORD="${before##*[$'\t ']}"
    local after="${line_text:${#before}}"
    local rest="${after%%[$'\t ']*}"
    TOKEN="${WORD}${rest}"
}

# Return the word at the given line and character in the given text.
# The word is the run of non-whitespace characters that contains the given
# character position. Any trailing =value suffix is stripped so that
# --fstype=ext4 returns --fstype.
word_at() {
    local TOKEN WORD
    _token_at "$1" "$2" "$3"
    printf '%s' "${TOKEN%%=*}"
}

# If the cursor is positioned in the value part of a flag=value token, return
# the flag name (e.g. --fstype=ext4 with cursor on ext4 returns --fstype).
# Also handles the cursor-on-whitespace case where the editor triggers
# completion immediately after typing 'flag=' before any value character
# (e.g. '--fstype= ' with cursor on the space): in that case WORD is empty
# but the token to the left ends with '=', so we step one character back.
# Returns empty string if the cursor is not in a value position.
flag_at() {
    local TOKEN WORD
    _token_at "$1" "$2" "$3"
    if [[ -z "$WORD" && "$3" -gt 0 ]]; then
        _token_at "$1" "$2" "$(($3 - 1))"
    fi
    [[ "$TOKEN" != *=* ]] && return 0
    [[ "$WORD"  != *=* ]] && return 0
    printf '%s' "${TOKEN%%=*}"
}

# If the cursor is positioned on the value of a space-separated flag
# (e.g. '--ptable gpt' with cursor on 'gpt', or '--ptable ' with cursor on
# the space), return the flag name.  Returns empty string otherwise.
prev_flag_at() {
    local text="$1" line="$2" character="$3"
    local line_text
    line_text="$(printf '%s' "$text" | sed -n "$((line + 1))p")"
    # Include the character at the cursor so a trailing space is visible.
    local before="${line_text:0:$((character + 1))}"
    # Strip the last non-whitespace run (partial word at cursor) from before
    local no_partial
    no_partial="$(printf '%s' "$before" | sed 's/[^[:space:]]*$//')"
    # Strip trailing whitespace to land at end of the preceding token
    local trimmed
    trimmed="$(printf '%s' "$no_partial" | sed 's/[[:space:]]*$//')"
    # The preceding token is the last whitespace-delimited word
    local prev="${trimmed##*[$'\t ']}"
    # Only return if the preceding token is a flag (starts with --)
    [[ "$prev" == --* ]] || return 0
    printf '%s' "$prev"
}

# Return the leading directive keyword of the given line (bootloader, part, or
# partition), or empty string if the line does not start with a known directive.
directive_at() {
    local text="$1" line="$2"
    local line_text first_token
    line_text="$(printf '%s' "$text" | sed -n "$((line + 1))p")"
    first_token="${line_text%%[$'\t ']*}"
    case "$first_token" in
        bootloader|part|partition) printf '%s' "$first_token" ;;
    esac
}

# Return true if the cursor is at the start of a line, meaning there is no
# non-whitespace content before it. Used to decide whether to offer keyword
# completions (bootloader/part/partition) or flag completions.
line_start_at() {
    local text="$1" line="$2" character="$3"
    local line_text before
    line_text="$(printf '%s' "$text" | sed -n "$((line + 1))p")"
    before="${line_text:0:${character}}"
    [[ -z "${before//[$'\t ']}" ]]
}

# Walk up the directory tree from the given path (which may be a file or
# directory) until a directory containing oe-init-build-env is found.
# Prints the root directory and returns 0, or returns 1 if not found.
find_oe_root() {
    local path="$1"
    local dir
    # Start from the directory containing the path.
    if [[ -d "$path" ]]; then
        dir="$path"
    else
        dir="${path%/*}"
    fi
    while [[ -n "$dir" && "$dir" != "/" ]]; do
        if [[ -e "$dir/oe-init-build-env" ]]; then
            printf '%s' "$dir"
            return 0
        fi
        dir="${dir%/*}"
    done
    return 1
}

# Given an OE root directory and a source plugin name, print the absolute path
# to the plugin's Python source file and return 0.  Returns 1 if the file does
# not exist.
source_plugin_path() {
    local oe_root="$1" plugin_name="$2"
    local path="$oe_root/scripts/lib/wic/plugins/source/${plugin_name}.py"
    if [[ -f "$path" ]]; then
        printf '%s' "$path"
        return 0
    fi
    return 1
}

# Given a plugin Python source file, print the 0-indexed line and character of
# the plugin class name and return 0.  Returns 1 if no class line is found.
plugin_class_position() {
    local file="$1"
    local lineno=0 line_text
    while IFS= read -r line_text; do
        if [[ "$line_text" == class\ * ]]; then
            # "class " is 6 characters; the class name starts at character 6.
            printf '%d %d' "$lineno" 6
            return 0
        fi
        lineno=$((lineno + 1))
    done < "$file"
    return 1
}

# If the cursor is positioned on the value of a --source flag (either
# --source=<name> with cursor on <name>, or --source <name> with cursor on
# <name>), print the plugin name and return 0.  Returns 1 otherwise.
source_value_at() {
    local text="$1" line="$2" character="$3"
    local flag
    # Check --source=<name> form (cursor in value of = token).
    flag="$(flag_at "$text" "$line" "$character")"
    if [[ "$flag" == "--source" ]]; then
        local TOKEN WORD
        _token_at "$text" "$line" "$character"
        printf '%s' "${TOKEN#*=}"
        return 0
    fi
    # Check --source <name> form (cursor on space-separated value).
    flag="$(prev_flag_at "$text" "$line" "$character")"
    if [[ "$flag" == "--source" ]]; then
        local TOKEN WORD
        _token_at "$text" "$line" "$character"
        # TOKEN is the plugin name (strip any =value suffix just in case).
        printf '%s' "${TOKEN%%=*}"
        return 0
    fi
    return 1
}

# Send a hover response with a markdown value.
send_hover() {
    local id="$1" doc="$2"
    local value
    value="$(jq -cn --arg v "$doc" '$v')"
    send "{\"jsonrpc\":\"2.0\",\"id\":${id},\"result\":{\"contents\":{\"kind\":\"markdown\",\"value\":${value}}}}"
}

# Send a completion response.
# context is one of:
#   "keywords"          — return only directive keywords (bootloader, part, partition)
#   "bootloader_flags"  — return only bootloader flag names
#   "part_flags"        — return only part/partition flag names
#   "--fstype"          — return enumerated fstype values
#   "--ptable"          — return enumerated ptable values
#   "--source"          — return known source plugin names
send_completion() {
    local id="$1" context="${2:-part_flags}"
    local jq_prog items

    case "$context" in
        keywords)
            jq_prog='[
                {label:"bootloader", kind:14},
                {label:"part",       kind:14},
                {label:"partition",  kind:14}
            ]'
            ;;
        --fstype)
            jq_prog='[
                {label:"btrfs",    kind:12},
                {label:"efi",      kind:12},
                {label:"erofs",    kind:12},
                {label:"ext2",     kind:12},
                {label:"ext3",     kind:12},
                {label:"ext4",     kind:12},
                {label:"msdos",    kind:12},
                {label:"squashfs", kind:12},
                {label:"swap",     kind:12},
                {label:"vfat",     kind:12}
            ]'
            ;;
        --ptable)
            jq_prog='[
                {label:"gpt",   kind:12},
                {label:"msdos", kind:12}
            ]'
            ;;
        --source)
            jq_prog='[
                {label:"bootimg_biosplusefi", kind:12},
                {label:"bootimg_efi",         kind:12},
                {label:"bootimg_partition",   kind:12},
                {label:"bootimg_pcbios",      kind:12},
                {label:"empty",               kind:12},
                {label:"extra_partition",     kind:12},
                {label:"isoimage_isohybrid",  kind:12},
                {label:"rawcopy",             kind:12},
                {label:"rootfs",              kind:12}
            ]'
            ;;
        bootloader_flags)
            jq_prog='[
                {label:"--append",     kind:5},
                {label:"--configfile", kind:5},
                {label:"--ptable",     kind:5},
                {label:"--timeout",    kind:5}
            ]'
            ;;
        part_flags)
            jq_prog='[
                {label:"--active",                 kind:5},
                {label:"--align",                  kind:5},
                {label:"--exclude-path",           kind:5},
                {label:"--extra-filesystem-space", kind:5},
                {label:"--extra-partition-space",  kind:5},
                {label:"--fixed-size",             kind:5},
                {label:"--fsoptions",              kind:5},
                {label:"--fstype",                 kind:5},
                {label:"--fsuuid",                 kind:5},
                {label:"--label",                  kind:5},
                {label:"--mkfs-extraopts",         kind:5},
                {label:"--no-table",               kind:5},
                {label:"--offset",                 kind:5},
                {label:"--ondisk",                 kind:5},
                {label:"--ondrive",                kind:5},
                {label:"--overhead-factor",        kind:5},
                {label:"--part-name",              kind:5},
                {label:"--part-type",              kind:5},
                {label:"--rootfs",                 kind:5},
                {label:"--rootfs-dir",             kind:5},
                {label:"--size",                   kind:5},
                {label:"--source",                 kind:5},
                {label:"--sourceparams",           kind:5},
                {label:"--system-id",              kind:5},
                {label:"--use-uuid",               kind:5},
                {label:"--uuid",                   kind:5}
            ]'
            ;;
        *)
            send "{\"jsonrpc\":\"2.0\",\"id\":${id},\"result\":null}"
            return
            ;;
    esac
    items="$(jq -cn "$jq_prog")"
    send "{\"jsonrpc\":\"2.0\",\"id\":${id},\"result\":${items}}"
}

BOOTLOADER_DOC="$(cat <<'HEREDOC'
## Command: bootloader

This command specifies how the bootloader should be configured and supports the following options:

> **Note:** Bootloader functionality and boot partitions are implemented by the various source plugins that implement bootloader functionality. The bootloader command essentially provides a means of modifying bootloader configuration.

- `--append`: Specifies kernel parameters. These parameters will be added to the syslinux APPEND or `grub` kernel command line.

- `--configfile`: Specifies a user-defined configuration file for the bootloader. You can provide a full pathname for the file or a file located in the `canned-wks` folder. This option overrides all other bootloader options.

- `--ptable`: Specifies the partition table format. Valid values are:
  - `msdos`
  - `gpt`

- `--timeout`: Specifies the number of seconds before the bootloader times out and boots the default option.
HEREDOC
)"

PART_DOC="$(cat <<'HEREDOC'
## Command: part or partition

Either of these commands creates a partition on the system.

The `mntpoint` must be one of:
- `/path`: For example, "/", "/usr", or "/home"
- `swap`: The created partition is used as swap space

> **Note:** The mount program must understand the PARTUUID syntax you use with `--use-uuid` and non-root mountpoint, including swap.

- `--size`: The minimum partition size. Integer with optional unit k/K (kibibyte), M (mebibyte), G (gibibyte). Default: M.

- `--fixed-size`: The exact partition size. Cannot be used with `--size`.

- `--source`: Names the source of data that populates the partition. Common value: `rootfs`.

- `--ondisk` / `--ondrive`: Forces the partition onto a particular disk.

- `--fstype`: Filesystem type. Valid values: `btrfs`, `erofs`, `ext2`, `ext3`, `ext4`, `squashfs`, `swap`, `vfat`.

- `--fsoptions`: Free-form mount options string, copied into `/etc/fstab`. Default: "defaults".

- `--label`: Label for the filesystem on the partition.

- `--active`: Marks the partition as active.

- `--align`: Start partition on boundaries of x KBytes.

- `--offset`: Place the partition at exactly the specified offset. Units: s/S (512-byte sector), k/K, M, G. Default: k.

- `--no-table`: Reserves space and populates the partition but does not add it to the partition table.

- `--exclude-path`: Excludes the given relative path from the image. Only effective with the rootfs source plugin.

- `--extra-filesystem-space`: Extra space after partition content. Default: 10M.

- `--extra-partition-space`: Extra empty space after the filesystem. Default: 0M.

- `--overhead-factor`: Multiplies the partition size. Must be >= 1. Default: 1.3.

- `--part-name`: Name for GPT partitions.

- `--part-type`: Partition type GUID for GPT partitions.

- `--use-uuid`: Generate a random GUID for the partition, used in bootloader config.

- `--uuid`: Specifies the partition UUID.

- `--fsuuid`: Specifies the filesystem UUID.

- `--system-id`: Partition system ID (one byte hexadecimal).

- `--mkfs-extraopts`: Additional options passed to the `mkfs` utility.
HEREDOC
)"

